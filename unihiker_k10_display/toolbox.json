{
  "kind": "category",
  "name": "K10屏幕显示",
  "icon": "fa-light fa-display",
  "colour": "#2196F3",
  "contents": [
    {
      "kind": "label",
      "text": "初始化"
    },
    {
      "kind": "block",
      "type": "k10_init_screen"
    },
    {
      "kind": "block",
      "type": "k10_set_background"
    },
    {
      "kind": "label",
      "text": "绘图"
    },
    {
      "kind": "block",
      "type": "k10_draw_point",
      "inputs": {
        "X": { "shadow": { "type": "math_number", "fields": { "NUM": 120 } } },
        "Y": { "shadow": { "type": "math_number", "fields": { "NUM": 160 } } }
      }
    },
    {
      "kind": "block",
      "type": "k10_draw_line",
      "inputs": {
        "X1": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } },
        "Y1": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } },
        "X2": { "shadow": { "type": "math_number", "fields": { "NUM": 240 } } },
        "Y2": { "shadow": { "type": "math_number", "fields": { "NUM": 320 } } }
      }
    },
    {
      "kind": "block",
      "type": "k10_set_line_width"
    },
    {
      "kind": "block",
      "type": "k10_draw_circle",
      "inputs": {
        "X": { "shadow": { "type": "math_number", "fields": { "NUM": 120 } } },
        "Y": { "shadow": { "type": "math_number", "fields": { "NUM": 160 } } },
        "R": { "shadow": { "type": "math_number", "fields": { "NUM": 40 } } }
      }
    },
    {
      "kind": "block",
      "type": "k10_draw_rectangle",
      "inputs": {
        "X": { "shadow": { "type": "math_number", "fields": { "NUM": 40 } } },
        "Y": { "shadow": { "type": "math_number", "fields": { "NUM": 40 } } },
        "W": { "shadow": { "type": "math_number", "fields": { "NUM": 160 } } },
        "H": { "shadow": { "type": "math_number", "fields": { "NUM": 240 } } }
      }
    },
    {
      "kind": "label",
      "text": "文字"
    },
    {
      "kind": "block",
      "type": "k10_draw_text_simple",
      "inputs": {
        "TEXT": { "shadow": { "type": "text", "fields": { "TEXT": "Hello K10" } } }
      }
    },
    {
      "kind": "block",
      "type": "k10_draw_text",
      "inputs": {
        "TEXT": { "shadow": { "type": "text", "fields": { "TEXT": "Hello K10" } } },
        "X": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } },
        "Y": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } }
      }
    },
    {
      "kind": "label",
      "text": "图片"
    },
    {
      "kind": "block",
      "type": "k10_draw_bitmap",
      "inputs": {
        "X": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } },
        "Y": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } },
        "W": { "shadow": { "type": "math_number", "fields": { "NUM": 100 } } },
        "H": { "shadow": { "type": "math_number", "fields": { "NUM": 100 } } }
      }
    },
    {
      "kind": "block",
      "type": "k10_draw_image",
      "inputs": {
        "PATH": { "shadow": { "type": "text", "fields": { "TEXT": "S:/photo.bmp" } } },
        "X": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } },
        "Y": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } }
      }
    },
    {
      "kind": "block",
      "type": "k10_draw_qrcode",
      "inputs": {
        "CONTENT": { "shadow": { "type": "text", "fields": { "TEXT": "https://www.unihiker.com.cn" } } }
      }
    },
    {
      "kind": "label",
      "text": "画布控制"
    },
    {
      "kind": "block",
      "type": "k10_update_canvas"
    },
    {
      "kind": "block",
      "type": "k10_clear_canvas"
    }
  ]
}
